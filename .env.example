# Costguard proxy
COSTGUARD_URL=http://localhost:8080
COSTGUARD_AGENT=forge
COSTGUARD_TEAM=
COSTGUARD_PROJECT=
COSTGUARD_TIMEOUT=60s
COSTGUARD_MAX_RETRIES=3

# Models
# FORGE_COMPILER_MODEL is the base model; unset role-specific vars fall back to it.
# COMPILER_MODEL is a backwards-compatible alias for FORGE_COMPILER_MODEL.
COMPILER_MODEL=claude-sonnet-4-6
FORGE_COMPILER_MODEL=claude-sonnet-4-6

FORGE_PLANNER_MODEL=         # defaults to FORGE_COMPILER_MODEL if unset
FORGE_CODER_MODEL=           # defaults to FORGE_COMPILER_MODEL if unset
FORGE_COMPACTOR_MODEL=       # defaults to FORGE_COMPILER_MODEL if unset

# Leave blank to disable the intent → tool-call two-step (single-model mode).
# Set to a model name (e.g. claude-haiku-4-5-20251001) to enable a cheap/local
# tool-caller that converts planner INTENT: statements into TOOL:/ARGS: calls.
FORGE_TOOL_CALLER_MODEL=

# Leave blank to disable semantic search (falls back to grep).
FORGE_EMBEDDING_MODEL=

# Patch reviewer model. After a patch passes validation, one Costguard call is
# made to this model to check correctness before showing the patch to the user.
# Unset (default): falls back to FORGE_PLANNER_MODEL — review is enabled.
# Set to a model name: that model is used for review.
# Set to empty string explicitly (FORGE_REVIEWER_MODEL=): disables review entirely.
FORGE_REVIEWER_MODEL=

# Output token limits — how many tokens the model can generate in its response.
FORGE_COMPILER_MAX_TOKENS=8000
FORGE_PLANNER_MAX_TOKENS=12000
FORGE_CODER_MAX_TOKENS=16000
FORGE_TOOL_CALLER_MAX_TOKENS=300
FORGE_COMPACTOR_MAX_TOKENS=2500
FORGE_REVIEWER_MAX_TOKENS=1200
FORGE_EMBEDDING_MAX_TOKENS=100

# Context window limits — when estimated input tokens exceed this, older history
# is summarised (compacted) before the call. Defaults to the corresponding
# MAX_TOKENS value above when unset, preserving backwards compatibility.
# Set these higher than MAX_TOKENS to allow a large context before compacting
# while keeping MAX_TOKENS tight to cap output length.
# Example: FORGE_PLANNER_CONTEXT_TOKENS=32000 with FORGE_PLANNER_MAX_TOKENS=4000
# means the planner sees up to 32k of history but can only write 4k per response.
FORGE_PLANNER_CONTEXT_TOKENS=
FORGE_CODER_CONTEXT_TOKENS=
FORGE_TOOL_CALLER_CONTEXT_TOKENS=
FORGE_COMPACTOR_CONTEXT_TOKENS=

# Debug
FORGE_DEBUG=false
