# Costguard proxy
COSTGUARD_URL=http://localhost:8080
COSTGUARD_MODE=balanced        # cheap | balanced | best | private
COSTGUARD_AGENT=forge
COSTGUARD_PROVIDER=             # local_ollama | anthropic_primary | openai_primary | google_primary
COSTGUARD_TEAM=
COSTGUARD_PROJECT=
COSTGUARD_TIMEOUT=60s
COSTGUARD_MAX_RETRIES=3

# Compiler
COMPILER_MODEL=claude-sonnet-4-6
FORGE_COMPILER_MODEL=claude-sonnet-4-6
FORGE_AGENT_MODEL=claude-sonnet-4-6

# Debug
FORGE_DEBUG=false
