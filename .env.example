# Costguard proxy
COSTGUARD_URL=http://localhost:8080
COSTGUARD_MODE=balanced        # cheap | balanced | best | private
COSTGUARD_AGENT=forge
COSTGUARD_PROVIDER=            # local_ollama | anthropic | openai | ...
COSTGUARD_TEAM=
COSTGUARD_PROJECT=
COSTGUARD_TIMEOUT=60s
COSTGUARD_MAX_RETRIES=3

# Compiler
COMPILER_MODEL=claude-haiku-4-5-20251001

# Debug
FORGE_DEBUG=false
